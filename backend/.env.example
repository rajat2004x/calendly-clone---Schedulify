PORT=5000

# Backend/frontend origin + auth secrets
CLIENT_URL=
JWT_SECRET=
BASE_URL=

# Requested OAuth placeholders (set when implementing Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Requested Mongo placeholder (this project currently uses MySQL/Sequelize)
MONGO_URI=

# MySQL (used by current backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=calendly_clone
DB_USER=root
DB_PASSWORD=
DB_SYNC_ALTER=false

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_USER=noreply@schedulify.com
